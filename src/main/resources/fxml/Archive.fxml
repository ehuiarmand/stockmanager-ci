<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.inphb.icgl.stocks.controller.ArchiveController">
    <top>
        <VBox spacing="8.0" style="-fx-padding: 12;">
            <Label styleClass="title" text="Archives des mouvements supprimes"/>
            <Label text="Historique archive lors de la suppression d'un produit"/>
        </VBox>
    </top>
    <center>
        <TableView fx:id="tableArchives">
            <columns>
                <TableColumn fx:id="colId" prefWidth="55.0" text="ID"/>
                <TableColumn fx:id="colIdOrigine" prefWidth="90.0" text="ID Mvt"/>
                <TableColumn fx:id="colIdProduit" prefWidth="90.0" text="ID Produit"/>
                <TableColumn fx:id="colType" prefWidth="90.0" text="Type"/>
                <TableColumn fx:id="colQuantite" prefWidth="80.0" text="Qte"/>
                <TableColumn fx:id="colMotif" prefWidth="220.0" text="Motif"/>
                <TableColumn fx:id="colIdUtilisateur" prefWidth="90.0" text="ID User"/>
                <TableColumn fx:id="colDateMouvement" prefWidth="170.0" text="Date Mvt"/>
                <TableColumn fx:id="colDateArchivage" prefWidth="170.0" text="Date Archivage"/>
            </columns>
        </TableView>
    </center>
    <bottom>
        <HBox spacing="10.0" style="-fx-padding: 8;">
            <Button fx:id="btnPrev" onAction="#handlePrevPage" text="Precedent"/>
            <Button fx:id="btnNext" onAction="#handleNextPage" text="Suivant"/>
            <Label fx:id="lblPagination" text="Page 1/1"/>
        </HBox>
    </bottom>
</BorderPane>

