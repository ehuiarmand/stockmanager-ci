<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.inphb.icgl.stocks.controller.CategorieController" styleClass="app-root">
    <top>
        <VBox spacing="10.0" styleClass="content-card compact-card" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="12.0" right="14.0" bottom="10.0" left="14.0"/>
            </padding>
            <Label styleClass="title" text="Gestion des categories"/>
            <HBox spacing="8.0" styleClass="search-bar">
                <Label prefWidth="95.0" styleClass="search-label" text="Recherche :"/>
                <TextField fx:id="txtRecherche" prefWidth="320.0" promptText="Rechercher par libelle..." styleClass="search-field"/>
                <Label fx:id="lblStatut" styleClass="status-label"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="12.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/>
            </padding>
            <TableView fx:id="tableCategories" styleClass="app-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="80.0" text="ID"/>
                    <TableColumn fx:id="colLibelle" prefWidth="240.0" text="Libelle"/>
                    <TableColumn fx:id="colDescription" prefWidth="420.0" text="Description"/>
                </columns>
            </TableView>
            <TitledPane animated="false" collapsible="false" expanded="true" styleClass="form-pane" text="Formulaire categorie">
                <content>
                    <VBox spacing="12.0" styleClass="form-content">
                        <padding>
                            <Insets top="12.0" right="14.0" bottom="12.0" left="14.0"/>
                        </padding>
                        <GridPane styleClass="form-grid">
                            <columnConstraints>
                                <ColumnConstraints minWidth="120.0" prefWidth="140.0"/>
                                <ColumnConstraints minWidth="320.0" prefWidth="420.0" hgrow="ALWAYS"/>
                            </columnConstraints>
                            <Label styleClass="form-label" text="Libelle:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <TextField fx:id="txtLibelle" prefHeight="31.0" promptText="Ex: Quincaillerie" styleClass="form-field" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                            <Label styleClass="form-label" text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                            <TextField fx:id="txtDescription" prefHeight="31.0" promptText="Description de la categorie" styleClass="form-field" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                            <Label styleClass="helper-label" text="Le libelle doit etre unique. La suppression est bloquee si des produits utilisent cette categorie." GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                        </GridPane>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="action-bar">
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="btnAjouter" onAction="#handleAjouter" prefHeight="39.0" prefWidth="104.0" style="-fx-background-color:#49B765; -fx-border-color:#2E8E49; -fx-border-width:1.4; -fx-text-fill:white; -fx-font-size:14px; -fx-font-weight:700; -fx-background-radius:7; -fx-border-radius:7; -fx-opacity:1;" styleClass="action-button add-button button-success" text="+ Ajouter"/>
                            <Button fx:id="btnModifier" onAction="#handleModifier" prefHeight="39.0" prefWidth="108.0" style="-fx-background-color:#2F80ED; -fx-border-color:#1F5FB9; -fx-border-width:1.4; -fx-text-fill:white; -fx-font-size:14px; -fx-font-weight:700; -fx-background-radius:7; -fx-border-radius:7; -fx-opacity:1;" styleClass="action-button edit-button button-primary" text="Modifier"/>
                            <Button fx:id="btnSupprimer" onAction="#handleSupprimer" prefHeight="39.0" prefWidth="142.0" style="-fx-background-color:#E28A00; -fx-border-color:#B66D00; -fx-border-width:1.4; -fx-text-fill:white; -fx-font-size:14px; -fx-font-weight:700; -fx-background-radius:7; -fx-border-radius:7; -fx-opacity:1;" styleClass="action-button delete-button button-danger" text="⚠ Supprimer"/>
                        </HBox>
                    </VBox>
                </content>
            </TitledPane>
        </VBox>
    </center>
    <bottom>
        <HBox spacing="10.0" styleClass="footer-bar">
            <Button fx:id="btnPrev" onAction="#handlePrevPage" styleClass="refresh-button" text="Precedent"/>
            <Button fx:id="btnNext" onAction="#handleNextPage" styleClass="refresh-button" text="Suivant"/>
            <Label fx:id="lblPagination" styleClass="status-label" text="Page 1/1"/>
        </HBox>
    </bottom>
</BorderPane>
