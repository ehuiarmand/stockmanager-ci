<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.inphb.icgl.stocks.controller.MouvementController" styleClass="app-root">
    <top>
        <VBox spacing="8.0" styleClass="content-card">
            <padding>
                <Insets top="12.0" right="12.0" bottom="8.0" left="12.0"/>
            </padding>
            <Label styleClass="title" text="Mouvements de stock"/>
            <GridPane hgap="8.0" vgap="8.0">
                <ComboBox fx:id="cbProduit" prefWidth="230.0" promptText="Produit" styleClass="form-combo" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <ComboBox fx:id="cbType" prefWidth="130.0" promptText="Type" styleClass="form-combo" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <TextField fx:id="txtQuantite" promptText="Quantite" styleClass="form-field" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <TextField fx:id="txtMotif" promptText="Motif" styleClass="form-field" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                <Button onAction="#handleEnregistrer" styleClass="action-button success-button button-success" text="Enregistrer" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
                <Label fx:id="lblStatut" styleClass="status-label" GridPane.columnIndex="5" GridPane.rowIndex="0"/>
            </GridPane>
            <HBox spacing="8.0" styleClass="search-bar">
                <Label styleClass="search-label" text="Filtre produit"/>
                <ComboBox fx:id="cbFiltreProduit" prefWidth="220.0" styleClass="form-combo"/>
                <Label styleClass="search-label" text="Du"/>
                <DatePicker fx:id="dpDebut"/>
                <Label styleClass="search-label" text="Au"/>
                <DatePicker fx:id="dpFin"/>
                <Button onAction="#handleFiltrer" styleClass="action-button primary-button button-primary" text="Filtrer"/>
                <Button onAction="#handleResetFiltre" styleClass="action-button neutral-button button-secondary" text="Reinitialiser"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="tableMouvements" styleClass="app-table">
            <columns>
                <TableColumn fx:id="colId" prefWidth="60.0" text="ID"/>
                <TableColumn fx:id="colProduit" prefWidth="220.0" text="Produit"/>
                <TableColumn fx:id="colType" prefWidth="90.0" text="Type"/>
                <TableColumn fx:id="colQuantite" prefWidth="90.0" text="Qte"/>
                <TableColumn fx:id="colMotif" prefWidth="240.0" text="Motif"/>
                <TableColumn fx:id="colUtilisateur" prefWidth="180.0" text="Utilisateur"/>
                <TableColumn fx:id="colDate" prefWidth="180.0" text="Date"/>
            </columns>
        </TableView>
    </center>
    <bottom>
        <HBox spacing="10.0" styleClass="footer-bar">
            <Button fx:id="btnPrev" onAction="#handlePrevPage" styleClass="refresh-button" text="Precedent"/>
            <Button fx:id="btnNext" onAction="#handleNextPage" styleClass="refresh-button" text="Suivant"/>
            <Label fx:id="lblPagination" styleClass="status-label" text="Page 1/1"/>
        </HBox>
    </bottom>
</BorderPane>
