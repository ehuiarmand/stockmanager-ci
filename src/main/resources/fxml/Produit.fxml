<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.inphb.icgl.stocks.controller.ProduitController" styleClass="app-root">
    <top>
        <VBox spacing="8.0" styleClass="content-card compact-card product-header-card">
            <padding>
                <Insets top="12.0" right="12.0" bottom="8.0" left="12.0"/>
            </padding>
            <Label styleClass="title" text="Gestion des produits"/>
            <HBox spacing="8.0" styleClass="search-bar">
                <TextField fx:id="txtRecherche" promptText="Ciment..." styleClass="search-field product-search-field"/>
                <Button onAction="#handleExporter" prefHeight="34.0" prefWidth="170.0" styleClass="action-button export-button button-warning" text="Exporter XLSX"/>
                <Button onAction="#handleExporterPdf" prefHeight="34.0" prefWidth="150.0" styleClass="action-button pdf-button button-primary" text="Exporter PDF"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label styleClass="search-label" text="En alerte:"/>
                <Label fx:id="lblAlerte" styleClass="danger" text="0"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="12.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="12.0" right="12.0" bottom="12.0" left="12.0"/>
            </padding>
            <TitledPane animated="false" collapsible="false" expanded="true" styleClass="form-pane" text="Saisie / Modification d'un produit">
                <content>
                    <VBox spacing="12.0" styleClass="form-content">
                        <padding>
                            <Insets top="12.0" right="14.0" bottom="12.0" left="14.0"/>
                        </padding>
                        <GridPane hgap="8.0" vgap="8.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>
                            <Label styleClass="form-label" text="R&#233;f&#233;rence *" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <Label styleClass="form-label" text="D&#233;signation *" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                            <Label styleClass="form-label" text="Cat&#233;gorie" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                            <Label styleClass="form-label" text="Fournisseur" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                            <TextField fx:id="txtReference" prefHeight="29.0" styleClass="form-field" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                            <TextField fx:id="txtDesignation" prefHeight="29.0" styleClass="form-field" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                            <ComboBox fx:id="cbCategorie" prefHeight="29.0" prefWidth="220.0" styleClass="form-combo" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                            <ComboBox fx:id="cbFournisseur" prefHeight="29.0" prefWidth="220.0" styleClass="form-combo" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                            <Label styleClass="form-label" text="Prix (FCFA) *" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                            <Label styleClass="form-label" text="Quantit&#233; *" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                            <Label styleClass="form-label" text="Stock min *" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                            <Label styleClass="form-label" text="Unit&#233;" GridPane.columnIndex="3" GridPane.rowIndex="2"/>
                            <TextField fx:id="txtPrix" prefHeight="29.0" styleClass="form-field" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                            <TextField fx:id="txtQuantite" prefHeight="29.0" styleClass="form-field" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                            <TextField fx:id="txtStockMin" prefHeight="29.0" styleClass="form-field" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
                            <TextField fx:id="txtUnite" prefHeight="29.0" styleClass="form-field" GridPane.columnIndex="3" GridPane.rowIndex="3"/>
                        </GridPane>
                        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="action-bar">
                            <Button fx:id="btnAjouter" onAction="#handleAjouter" prefHeight="39.0" prefWidth="112.0" style="-fx-background-color:#49B765; -fx-border-color:#2E8E49; -fx-border-width:1.4; -fx-text-fill:white; -fx-font-size:14px; -fx-font-weight:700; -fx-background-radius:7; -fx-border-radius:7; -fx-opacity:1;" styleClass="action-button add-button button-success" text="+ Ajouter"/>
                            <Button fx:id="btnModifier" onAction="#handleModifier" prefHeight="39.0" prefWidth="108.0" style="-fx-background-color:#2F80ED; -fx-border-color:#1F5FB9; -fx-border-width:1.4; -fx-text-fill:white; -fx-font-size:14px; -fx-font-weight:700; -fx-background-radius:7; -fx-border-radius:7; -fx-opacity:1;" styleClass="action-button edit-button button-primary" text="Modifier"/>
                            <Button fx:id="btnSupprimer" onAction="#handleSupprimer" prefHeight="39.0" prefWidth="142.0" style="-fx-background-color:#E28A00; -fx-border-color:#B66D00; -fx-border-width:1.4; -fx-text-fill:white; -fx-font-size:14px; -fx-font-weight:700; -fx-background-radius:7; -fx-border-radius:7; -fx-opacity:1;" styleClass="action-button delete-button button-danger" text="⚠ Supprimer"/>
                            <Button fx:id="btnVider" onAction="#handleVider" prefHeight="39.0" prefWidth="102.0" styleClass="action-button clear-button button-secondary" text="Vider"/>
                            <Label fx:id="lblStatut" styleClass="status-label product-status-label"/>
                        </HBox>
                    </VBox>
                </content>
            </TitledPane>
            <TableView fx:id="tableProduits" styleClass="app-table product-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colReference" prefWidth="130.0" text="R&#233;f&#233;rence"/>
                    <TableColumn fx:id="colDesignation" prefWidth="210.0" text="D&#233;signation"/>
                    <TableColumn fx:id="colCategorie" prefWidth="150.0" text="Cat&#233;gorie"/>
                    <TableColumn fx:id="colFournisseur" prefWidth="170.0" text="Fournisseur"/>
                    <TableColumn fx:id="colPrix" prefWidth="110.0" text="Prix FCFA"/>
                    <TableColumn fx:id="colQuantite" prefWidth="80.0" text="Qt&#233;"/>
                    <TableColumn fx:id="colStockMin" prefWidth="90.0" text="Min"/>
                    <TableColumn fx:id="colUnite" prefWidth="80.0" text="Unit&#233;"/>
                </columns>
            </TableView>
        </VBox>
    </center>
    <bottom>
        <HBox spacing="10.0" styleClass="footer-bar">
            <Button fx:id="btnPrev" onAction="#handlePrevPage" styleClass="refresh-button" text="Precedent"/>
            <Button fx:id="btnNext" onAction="#handleNextPage" styleClass="refresh-button" text="Suivant"/>
            <Label fx:id="lblPagination" styleClass="status-label" text="Page 1/1"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label styleClass="helper-alert" text="Lignes rouges = produits en alerte (quantit&#233; stock &lt;= stock minimum)"/>
        </HBox>
    </bottom>
</BorderPane>
